{
  "name": "dataguard-mvp",
  "version": "1.0.0",
  "description": "DataGuard MVP - Data quality validation tool for engineers",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "dev:all": "concurrently \"npm run dev\" \"cd client && npm run dev\"",
    "client:build": "cd client && npm run build",
    "client:start": "cd client && npm run start"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.0.3",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "csv-parser": "^3.0.0",
    "pg": "^8.11.0",
    "mysql2": "^3.6.0",
    "mongodb": "^6.0.0",
    "concurrently": "^8.2.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "nodemon": "^2.0.20"
  },
