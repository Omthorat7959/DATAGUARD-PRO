# ─── Database ────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dataguard?retryWrites=true&w=majority

# ─── Security ────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
ENCRYPTION_KEY=optional_32_char_key_for_db_credential_encryption

# ─── Claude AI (Optional) ────────────────────────────────
# Get your key at https://console.anthropic.com
# Without this, DataGuard uses a rule-based fallback analyzer
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxx

# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000
BCRYPT_ROUNDS=10
